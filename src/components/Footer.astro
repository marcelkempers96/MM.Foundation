---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="logo">
          <img src="/MiMaji-Foundation-Logo.png" alt="MiMaji Foundation logo" width="40" height="40" />
          MiMaji Foundation
        </div>
        <p>Clean water access for every community. A non-profit initiative powered by the MiMaji platform, headquartered in Nairobi, Kenya.</p>
      </div>
      <div class="footer-col">
        <h4>Foundation</h4>
        <a href="/about/">About Us</a>
        <a href="/the-problem/">The Water Crisis</a>
        <a href="/programs/">Programs</a>
        <a href="/impact/">Our Impact</a>
        <a href="/majimap/">MajiMap</a>
        <a href="/know-your-water/">Know Your Water</a>
        <a href="/stories/">Stories</a>
      </div>
      <div class="footer-col">
        <h4>Get Involved</h4>
        <a href="/take-action/">Take Action</a>
        <a href="/partners/">Partners</a>
        <a href="/water-in-schools/">Water in Schools</a>
        <a href="/resources/">Resources</a>
        <a href="/contact/">Contact Us</a>
        <a href="https://mimaji.co.ke" target="_blank" rel="noopener">Order Water on MiMaji</a>
      </div>
      <div class="footer-col">
        <h4>Contact</h4>
        <a href="mailto:foundation@mimaji.org">foundation@mimaji.org</a>
        <a href="https://wa.me/254758434076" target="_blank" rel="noopener">WhatsApp: +254 758 434 076</a>
        <span class="footer-static">Nairobi, Kenya</span>
        <a href="https://mimaji.co.ke" target="_blank" rel="noopener">MiMaji.co.ke</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {currentYear} MiMaji Foundation. All rights reserved. &bull; Headquartered in Nairobi, Kenya.</p>
      <p class="footer-stage">Pilot phase &mdash; Phase 1: Nairobi</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--dark);
    color: rgba(255, 255, 255, 0.6);
    padding: 4rem 2rem 2rem;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .logo {
    font-family: var(--serif);
    font-size: 1.4rem;
    color: var(--white);
    margin-bottom: 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }

  .logo img {
    width: 40px;
    height: 40px;
    object-fit: contain;
    background: rgba(255, 255, 255, 0.95);
    border-radius: 8px;
    padding: 3px;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--gold);
    display: inline-block;
  }

  .footer-brand p {
    font-size: 0.82rem;
    line-height: 1.7;
    max-width: 280px;
  }

  .footer-col h4 {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.3);
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .footer-col a {
    display: block;
    font-size: 0.85rem;
    margin-bottom: 0.6rem;
    transition: color 0.2s;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.6);
  }

  .footer-col a:hover {
    color: var(--gold);
  }

  .footer-static {
    display: block;
    font-size: 0.85rem;
    margin-bottom: 0.6rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .footer-stage {
    font-size: 0.7rem;
    color: var(--gold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-bottom p {
    font-size: 0.75rem;
    margin: 0;
  }

  @media (max-width: 900px) {
    .footer-top {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .footer-bottom {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
