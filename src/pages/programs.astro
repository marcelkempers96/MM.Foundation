---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Programs"
  description="MiMaji Foundation programs: water quality testing, community WASH education, platform-powered delivery, and water rights advocacy in Nairobi and East Africa."
>
  <section class="page-hero">
    <div class="hero-badge">What We Do</div>
    <h1>Our <em>Programs</em></h1>
    <p>Four programmes. One mission. Clean, verified water for every household.</p>
    <svg class="hero-wave" viewBox="0 0 1440 100" preserveAspectRatio="none">
      <path d="M0,60 C360,100 720,20 1080,60 C1260,80 1380,50 1440,60 L1440,100 L0,100Z" fill="white"/>
    </svg>
  </section>

  <!-- Programs Grid -->
  <section>
    <div class="section-inner">
      <div class="programs-grid fade-in">
        <div class="program">
          <img src="/water-testing-kit.png" alt="MiMaji Foundation water quality testing kit used in Nairobi community events for TDS and bacteriological analysis" loading="lazy" width="700" height="450" />
          <div class="content">
            <span class="tag">WATER QUALITY</span>
            <h3>Maji Safi Testing</h3>
            <p>Free testing in Nairobi estates. Open data feeds <a href="/majimap/" style="color: var(--gold);">MajiMap</a>.</p>
          </div>
        </div>
        <div class="program">
          <img src="/education-outreach-water-access.png" alt="MiMaji Foundation community education outreach session on safe water access in Nairobi" loading="lazy" width="700" height="450" />
          <div class="content">
            <span class="tag">EDUCATION</span>
            <h3>Community WASH Workshops</h3>
            <p>Practical training for schools, women's groups, and community health workers.</p>
          </div>
        </div>
        <div class="program">
          <img src="/water-station-nairobi-2026-2027.png" alt="Modern MiMaji water station in Nairobi providing verified clean drinking water through the MiMaji platform" loading="lazy" width="700" height="450" />
          <div class="content">
            <span class="tag">TECHNOLOGY</span>
            <h3>Platform Access</h3>
            <p>Subsidised <a href="https://mimaji.co.ke" target="_blank" rel="noopener" style="color: var(--gold);">MiMaji</a> delivery for vulnerable households.</p>
          </div>
        </div>
        <div class="program">
          <img src="/woman-filling-jug-from-borehole-tap.png" alt="A woman filling a jerrycan from a borehole tap in Nairobi, the everyday reality MiMaji Foundation works to change" loading="lazy" width="700" height="450" />
          <div class="content">
            <span class="tag">ADVOCACY</span>
            <h3>Water Rights &amp; Policy</h3>
            <p>Pushing for water equity, pricing transparency, and infrastructure investment.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Programme Details -->
  <section class="bg-sand">
    <div class="section-inner">
      <div class="section-label">How Each Programme Works</div>
      <div class="section-title">Built for Measurable Impact</div>
      <div class="details-grid fade-in">
        <div class="detail-card">
          <div class="detail-num">01</div>
          <h3>Maji Safi Testing Initiative</h3>
          <ul>
            <li>Free door-to-door water quality testing</li>
            <li>Real-time results shared with households</li>
            <li>Data feeds <a href="/majimap/">MajiMap</a> and the <a href="https://mimaji.co.ke" target="_blank" rel="noopener">MiMaji platform</a></li>
            <li>Quarterly community water safety reports</li>
          </ul>
        </div>
        <div class="detail-card">
          <div class="detail-num">02</div>
          <h3>Community WASH Workshops</h3>
          <ul>
            <li>Age-appropriate water education for schools</li>
            <li>Household treatment and safe storage</li>
            <li>Hygiene and handwashing campaigns</li>
            <li>Training community health workers as water champions</li>
          </ul>
        </div>
        <div class="detail-card">
          <div class="detail-num">03</div>
          <h3>Platform-Powered Delivery</h3>
          <ul>
            <li>Subsidised delivery for vulnerable households</li>
            <li>Verified water from tested sources</li>
            <li>Tracking and transparency through technology</li>
            <li>Sustainable model backed by platform revenue</li>
          </ul>
        </div>
        <div class="detail-card">
          <div class="detail-num">04</div>
          <h3>Water Rights &amp; Policy</h3>
          <ul>
            <li>Policy research and briefings</li>
            <li>Government and stakeholder engagement</li>
            <li>Water pricing transparency campaigns</li>
            <li>Infrastructure investment advocacy</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="section-title">Support Our Programmes</div>
    <p>Partner, donate, or volunteer. Every contribution moves us forward.</p>
    <div class="cta-buttons">
      <a href="/take-action/" class="btn btn-white">Take Action &rarr;</a>
      <a href="https://mimaji.co.ke" target="_blank" rel="noopener" class="btn btn-outline">Visit MiMaji Platform</a>
    </div>
  </section>
</BaseLayout>

<style>
  .details-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-top: 3rem;
  }

  .detail-card {
    padding: 2.2rem;
    border-radius: 16px;
    background: var(--white);
    border: 1px solid var(--border);
    transition: all 0.3s;
  }

  .detail-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(10, 94, 181, 0.1);
  }

  .detail-num {
    font-family: var(--serif);
    font-size: 2rem;
    color: var(--blue);
    opacity: 0.3;
    margin-bottom: 0.5rem;
  }

  .detail-card h3 {
    font-family: var(--serif);
    font-size: 1.2rem;
    color: var(--blue-deep);
    margin-bottom: 0.8rem;
  }

  .detail-card p {
    font-size: 0.88rem;
    color: var(--text-light);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .detail-card a {
    color: var(--blue);
    font-weight: 600;
  }

  .detail-card ul {
    list-style: none;
    padding: 0;
  }

  .detail-card ul li {
    font-size: 0.82rem;
    color: var(--text-light);
    padding: 0.35rem 0;
    padding-left: 1.2rem;
    position: relative;
  }

  .detail-card ul li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--teal);
    font-weight: 600;
  }

  @media (max-width: 900px) {
    .details-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
