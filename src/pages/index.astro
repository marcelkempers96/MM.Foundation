---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Home"
  description="MiMaji Foundation works to bring clean, safe, transparent water to every household in Nairobi and across East Africa. Water quality testing, community education, and the MajiMap data platform."
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-badge"><span class="pulse"></span> Phase 1: Nairobi, Kenya</div>
      <h1>Clean Water Is a Right,<br>Not a <em>Privilege</em></h1>
      <p>MiMaji Foundation builds water transparency for every household in East Africa. We start in Nairobi, where the need is greatest.</p>
      <div class="hero-buttons">
        <a href="/the-problem/" class="btn btn-primary">The Crisis &rarr;</a>
        <a href="/about/" class="btn btn-outline">Our Mission</a>
      </div>
      <div class="hero-stats">
        <div class="hero-stat"><span class="num">400M+</span><span class="label">Without Safe Water in Sub-Saharan Africa</span></div>
        <div class="hero-stat"><span class="num">10x</span><span class="label">Price Gap, Kibera vs Karen</span></div>
        <div class="hero-stat"><span class="num">2025</span><span class="label">Year Founded</span></div>
      </div>
    </div>
    <svg class="hero-wave" viewBox="0 0 1440 100" preserveAspectRatio="none">
      <path d="M0,60 C360,100 720,20 1080,60 C1260,80 1380,50 1440,60 L1440,100 L0,100Z" fill="white"/>
    </svg>
  </section>

  <!-- CRISIS -->
  <section class="bg-sand" id="crisis">
    <div class="section-inner">
      <div class="section-label">The Water Crisis</div>
      <div class="section-title">Africa Carries the World's Heaviest Water Burden</div>
      <div class="crisis-grid fade-in">
        <div class="crisis-visual">
          <img src="/women-carrying-water-jerrycans-kenya.png" alt="Women carrying water jerrycans on their backs in rural Kenya, the everyday water crisis MiMaji Foundation works to solve" loading="lazy" width="800" height="600" />
          <div class="overlay">
            <p>Women and girls in Kenya walk hours every day to collect water instead of attending school or earning a living.</p>
          </div>
        </div>
        <div class="crisis-facts">
          <div class="crisis-fact">
            <div class="icon">◈</div>
            <div>
              <h4>400 Million Lack Safe Water</h4>
              <p>Sub-Saharan Africa has the lowest access rates of any region in the world.</p>
            </div>
          </div>
          <div class="crisis-fact">
            <div class="icon">◇</div>
            <div>
              <h4>10x Price Gap in Nairobi</h4>
              <p>Households in Kibera pay up to ten times more per litre than those in Karen.</p>
            </div>
          </div>
          <div class="crisis-fact">
            <div class="icon">◆</div>
            <div>
              <h4>Waterborne Disease</h4>
              <p>Contaminated water is a leading cause of preventable death for children under five.</p>
            </div>
          </div>
          <div class="crisis-fact">
            <div class="icon">◉</div>
            <div>
              <h4>Economies Held Back</h4>
              <p>Water insecurity costs African economies billions annually in lost productivity.</p>
            </div>
          </div>
        </div>
      </div>
      <div class="section-cta-link">
        <a href="/the-problem/" class="btn btn-outline-dark">Read the full crisis briefing &rarr;</a>
      </div>
    </div>
  </section>

  <!-- MISSION -->
  <section id="mission">
    <div class="section-inner">
      <div class="section-label">What We Do</div>
      <div class="section-title">Three Pillars, One Mission</div>
      <div class="mission-cards">
        <div class="mission-card fade-in">
          <div class="card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M10 2v7.31"/>
              <path d="M14 9.3V2"/>
              <path d="M8.5 2h7"/>
              <path d="M14 9.3a6.5 6.5 0 1 1-4 0"/>
              <path d="M12 16v.01"/>
            </svg>
          </div>
          <h3>Water Quality Testing</h3>
          <p>Free testing in Nairobi communities. Open data for residents, vendors, and researchers.</p>
          <a href="/programs/" class="card-link">Our programmes &rarr;</a>
        </div>
        <div class="mission-card fade-in">
          <div class="card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3>Community Education</h3>
          <p>WASH workshops in schools and community groups. Practical, local, and lasting.</p>
          <a href="/water-in-schools/" class="card-link">Water in schools &rarr;</a>
        </div>
        <div class="mission-card fade-in">
          <div class="card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <h3>MajiMap Data</h3>
          <p>A public map of water quality, prices, and access across Nairobi.</p>
          <a href="/majimap/" class="card-link">Explore MajiMap &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ROADMAP -->
  <section class="bg-sand" id="roadmap">
    <div class="section-inner">
      <div class="section-label">Our Roadmap</div>
      <div class="section-title">What We're Building Now</div>
      <div class="stage-grid fade-in">
        <div class="stage-card">
          <div class="stage-image">
            <img src="/water-testing-kit.png" alt="MiMaji Foundation water quality testing kit used in Nairobi pilot community testing events" loading="lazy" width="1024" height="1536" />
          </div>
          <div class="stage-body">
            <div class="stage-tag">Now</div>
            <h4>Phase 1 Pilot</h4>
            <p>Water testing protocols and community events in Nairobi.</p>
          </div>
        </div>
        <div class="stage-card">
          <div class="stage-image">
            <img src="/MiMaji-research-kilimani-water.png" alt="MiMaji Foundation MajiMap research data from Kilimani, Nairobi water pricing study" loading="lazy" width="307" height="461" />
          </div>
          <div class="stage-body">
            <div class="stage-tag">Next</div>
            <h4>MajiMap Launch</h4>
            <p>Public, interactive Nairobi water price and quality map.</p>
          </div>
        </div>
        <div class="stage-card">
          <div class="stage-image">
            <img src="/education-outreach-water-access.png" alt="MiMaji Foundation community water education outreach session in a Nairobi neighbourhood" loading="lazy" width="410" height="614" />
          </div>
          <div class="stage-body">
            <div class="stage-tag">Soon</div>
            <h4>Schools Programme</h4>
            <p>Testing, ambassador training, and WASH education in Nairobi schools.</p>
          </div>
        </div>
        <div class="stage-card">
          <div class="stage-image">
            <img src="/modern-kenya-waterrefinery.png" alt="A modern Kenyan water refinery and treatment facility representing regional scaling vision for MiMaji Foundation" loading="lazy" width="1536" height="1024" />
          </div>
          <div class="stage-body">
            <div class="stage-tag">Vision</div>
            <h4>Regional Reach</h4>
            <p>Scaling proven programmes across East Africa.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="section-title">The Water Crisis Won't Solve Itself.</div>
    <p>Partner, donate, volunteer, or order water on the MiMaji platform. Every action moves us forward.</p>
    <div class="cta-buttons">
      <a href="/take-action/" class="btn btn-white">Take Action &rarr;</a>
      <a href="https://mimaji.co.ke" target="_blank" rel="noopener" class="btn btn-outline">Visit MiMaji Platform</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(165deg, var(--blue-deep) 0%, var(--blue) 40%, var(--sky) 100%);
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Ccircle cx='30' cy='30' r='2'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    z-index: 1;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('/close-up-shot-young-child-drinking-water.png');
    background-size: cover;
    background-position: center 25%;
    background-repeat: no-repeat;
    opacity: 0.35;
    mix-blend-mode: overlay;
    z-index: 1;
    pointer-events: none;
  }

  .hero-wave {
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 880px;
    padding: 2rem;
    animation: fadeUp 1s ease;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    padding: 0.45rem 1.2rem;
    border-radius: 50px;
    font-size: 0.78rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 1.8rem;
    letter-spacing: 0.04em;
  }

  .pulse {
    width: 8px;
    height: 8px;
    background: var(--gold);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  .hero h1 {
    font-family: var(--serif);
    font-weight: 700;
    font-size: clamp(2.6rem, 6vw, 4.5rem);
    color: var(--white);
    line-height: 1.1;
    margin-bottom: 1.2rem;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--gold);
  }

  .hero p {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: rgba(255, 255, 255, 0.8);
    max-width: 620px;
    margin: 0 auto 2.4rem;
    font-weight: 300;
    line-height: 1.8;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-stats {
    display: flex;
    gap: 3rem;
    justify-content: center;
    margin-top: 3.5rem;
    flex-wrap: wrap;
  }

  .hero-stat {
    text-align: center;
  }

  .hero-stat .num {
    font-family: var(--serif);
    font-size: 2.2rem;
    color: var(--white);
    display: block;
  }

  .hero-stat .label {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0.2rem;
  }

  .section-cta-link {
    text-align: center;
    margin-top: 3rem;
  }


  /* Stage cards */
  .stage-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .stage-card {
    border-radius: 16px;
    background: var(--white);
    border: 1px solid var(--border);
    transition: all 0.3s;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .stage-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(10, 94, 181, 0.08);
  }

  .stage-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--sand);
  }

  .stage-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .stage-body {
    padding: 1.6rem 1.4rem;
    flex-grow: 1;
  }

  .stage-tag {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    padding: 0.25rem 0.7rem;
    border-radius: 50px;
    background: rgba(244, 169, 48, 0.1);
    margin-bottom: 0.8rem;
  }

  .stage-card h4 {
    font-family: var(--serif);
    font-size: 1.1rem;
    color: var(--blue-deep);
    margin-bottom: 0.5rem;
  }

  .stage-card p {
    font-size: 0.85rem;
    color: var(--text-light);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .hero-stats {
      gap: 1.5rem;
    }

    .stage-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .hero h1 {
      font-size: 2rem;
    }

    .stage-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
