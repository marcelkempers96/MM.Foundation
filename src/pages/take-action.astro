---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Take Action"
  description="Get involved with MiMaji Foundation. Donate, volunteer, partner, or order water on the MiMaji platform. Every action moves us forward."
>
  <section class="page-hero">
    <div class="hero-badge">Make a Difference</div>
    <h1>Take <em>Action</em></h1>
    <p>Donate. Volunteer. Partner. Order water on the MiMaji platform. Every action moves us forward.</p>
    <svg class="hero-wave" viewBox="0 0 1440 100" preserveAspectRatio="none">
      <path d="M0,60 C360,100 720,20 1080,60 C1260,80 1380,50 1440,60 L1440,100 L0,100Z" fill="white"/>
    </svg>
  </section>

  <!-- Action Cards -->
  <section>
    <div class="section-inner">
      <div class="section-label">How You Can Help</div>
      <div class="section-title">Four Ways to Get Involved</div>

      <div class="action-grid fade-in">
        <div class="action-card donate">
          <img src="/M-PESA-payment.png" alt="M-Pesa mobile money payment screen showing how donations to MiMaji Foundation can be made via M-Pesa in Kenya" class="action-thumb" loading="lazy" width="600" height="400" />
          <h3>Donate</h3>
          <p>Your contribution funds water testing, community education, and subsidised delivery.</p>
          <ul>
            <li><strong>KES 500</strong> supports water quality testing</li>
            <li><strong>KES 2,000</strong> supports community education</li>
            <li><strong>KES 10,000</strong> supports subsidised clean water delivery</li>
          </ul>
          <div class="action-buttons">
            <a href="https://wa.me/254758434076?text=Hi%20MiMaji%20Foundation%2C%20I%27d%20like%20to%20donate." target="_blank" rel="noopener" class="btn btn-primary">Donate via WhatsApp &rarr;</a>
            <a href="/contact/" class="btn btn-outline-dark">Contact Us</a>
          </div>
        </div>

        <div class="action-card volunteer">
          <div class="action-icon">●</div>
          <h3>Volunteer</h3>
          <p>Join our Nairobi field teams and contribute directly.</p>
          <ul>
            <li>Water quality testing events</li>
            <li>Community outreach and education workshops</li>
            <li>Data collection for <a href="/majimap/">MajiMap</a></li>
            <li>School WASH programme facilitation</li>
          </ul>
          <a href="/contact/" class="btn btn-primary">Apply to Volunteer &rarr;</a>
        </div>

        <div class="action-card partner">
          <div class="action-icon">◆</div>
          <h3>Partner With Us</h3>
          <p>For organisations, institutions, and businesses ready to scale impact.</p>
          <ul>
            <li>Corporate social responsibility partnerships</li>
            <li>Research and academic collaborations</li>
            <li>Technology and data partnerships</li>
            <li>Implementing partner agreements</li>
          </ul>
          <a href="/contact/" class="btn btn-primary">Become a Partner &rarr;</a>
        </div>

        <div class="action-card spread">
          <div class="action-icon">▲</div>
          <h3>Spread the Word</h3>
          <p>Share our work with people who can help us go further.</p>
          <ul>
            <li>Share <a href="/majimap/">MajiMap</a> data on social media</li>
            <li>Forward our stories to your network</li>
            <li>Invite us to speak at your event</li>
            <li>Read and share our <a href="/stories/">stories</a></li>
          </ul>
          <a href="/stories/" class="btn btn-primary">Read Stories &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Order Water CTA -->
  <section class="bg-sand">
    <div class="section-inner">
      <div class="order-cta fade-in">
        <div class="order-content">
          <div class="section-label">Support Through Action</div>
          <h2>Order Water, Fund the Mission</h2>
          <p>Every order placed through the <a href="https://mimaji.co.ke" target="_blank" rel="noopener">MiMaji platform</a> supports our foundation's work. When you choose MiMaji, you fund clean water access for communities who need it most.</p>
          <a href="https://mimaji.co.ke" target="_blank" rel="noopener" class="btn btn-primary">Order on MiMaji.co.ke &rarr;</a>
        </div>
        <div class="order-visual">
          <img
            src="/20L-10L-bottles-tanks-nairobi-water-types.png"
            alt="MiMaji 10 litre and 20 litre water bottles, jerrycans and tanks delivered through the MiMaji platform in Nairobi"
            loading="lazy"
            width="600"
            height="600"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="section-title">Ready to Make a Difference?</div>
    <p>From KES 500 to a strategic partnership, every contribution moves us forward.</p>
    <div class="cta-buttons">
      <a href="/contact/" class="btn btn-white">Contact Us &rarr;</a>
      <a href="https://mimaji.co.ke" target="_blank" rel="noopener" class="btn btn-outline">Visit MiMaji Platform</a>
    </div>
  </section>
</BaseLayout>

<style>
  .action-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }

  .action-card {
    padding: 2.5rem;
    border-radius: 16px;
    border: 1px solid var(--border);
    background: var(--white);
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }

  .action-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    border-radius: 4px 4px 0 0;
  }

  .action-card.donate::before { background: var(--blue); }
  .action-card.volunteer::before { background: var(--teal); }
  .action-card.partner::before { background: var(--gold); }
  .action-card.spread::before { background: var(--sky); }

  .action-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(10, 94, 181, 0.1);
  }

  .action-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .action-thumb {
    width: 100%;
    aspect-ratio: 16/10;
    object-fit: cover;
    border-radius: 12px;
    margin-bottom: 1.2rem;
  }

  .action-card h3 {
    font-family: var(--serif);
    font-size: 1.4rem;
    color: var(--blue-deep);
    margin-bottom: 0.8rem;
  }

  .action-card > p {
    font-size: 0.9rem;
    color: var(--text-light);
    line-height: 1.7;
    margin-bottom: 1.2rem;
  }

  .action-card ul {
    list-style: none;
    padding: 0;
    margin-bottom: 1.5rem;
  }

  .action-card ul li {
    font-size: 0.85rem;
    color: var(--text-light);
    padding: 0.4rem 0;
    padding-left: 1.2rem;
    position: relative;
    line-height: 1.5;
  }

  .action-card ul li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--teal);
    font-weight: 600;
  }

  .action-card ul li a {
    color: var(--blue);
    font-weight: 600;
  }

  .action-buttons {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .order-cta {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .order-content h2 {
    font-family: var(--serif);
    font-size: 2rem;
    color: var(--blue-deep);
    margin-bottom: 1rem;
  }

  .order-content p {
    font-size: 0.95rem;
    color: var(--text-light);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .order-content a:not(.btn) {
    color: var(--blue);
    font-weight: 600;
  }

  .order-visual img {
    width: 100%;
    border-radius: 16px;
    box-shadow: 0 12px 40px rgba(10, 94, 181, 0.12);
  }

  @media (max-width: 900px) {
    .action-grid {
      grid-template-columns: 1fr;
    }

    .order-cta {
      grid-template-columns: 1fr;
    }
  }
</style>
