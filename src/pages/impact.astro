---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Impact"
  description="MiMaji Foundation impact: targets, SDG alignment, and the difference clean water makes for health, education, economy, and gender equality across East Africa."
>
  <section class="page-hero">
    <div class="hero-badge">Our Results</div>
    <h1>Our <em>Impact</em></h1>
    <p>Real targets. Real research. Real change in Nairobi and beyond.</p>
    <svg class="hero-wave" viewBox="0 0 1440 100" preserveAspectRatio="none">
      <path d="M0,60 C360,100 720,20 1080,60 C1260,80 1380,50 1440,60 L1440,100 L0,100Z" fill="white"/>
    </svg>
  </section>

  <!-- Vision Image -->
  <section>
    <div class="section-inner">
      <div class="vision-image fade-in">
        <img
          src="/modern-kenya-waterrefinery.png"
          alt="A modern Kenyan water refinery and treatment facility, the kind of infrastructure MiMaji Foundation supports through advocacy and partnerships"
          loading="lazy"
          width="1200"
          height="600"
        />
        <p class="image-caption">What success looks like: modern, transparent water infrastructure for every household in Kenya.</p>
      </div>
    </div>
  </section>

  <!-- Targets -->
  <section class="bg-sand">
    <div class="section-inner">
      <div class="section-label">2026 to 2027 Targets</div>
      <div class="section-title">Our Measurable Goals</div>
      <div class="targets-grid fade-in">
        <div class="target-card">
          <div class="target-metric">10,000</div>
          <div class="target-label">People reached through testing and education. <strong>Target.</strong></div>
        </div>
        <div class="target-card">
          <div class="target-metric">50</div>
          <div class="target-label">Communities mapped on <a href="/majimap/">MajiMap</a>. <strong>Target.</strong></div>
        </div>
        <div class="target-card">
          <div class="target-metric">50</div>
          <div class="target-label">Schools in the <a href="/water-in-schools/">WASH education programme</a>. <strong>Target.</strong></div>
        </div>
        <div class="target-card">
          <div class="target-metric">1</div>
          <div class="target-label">Country with active pilot. <strong>Kenya.</strong></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Impact Areas -->
  <section>
    <div class="section-inner">
      <div class="section-label">Impact Areas</div>
      <div class="section-title">Where Clean Water Changes Everything</div>
      <div class="impact-areas fade-in">
        <div class="impact-area">
          <div class="area-icon">▲</div>
          <h3>Health</h3>
          <p>Cleaner water means fewer cases of cholera, typhoid, and diarrhoea, especially in children under five.</p>
        </div>
        <div class="impact-area">
          <div class="area-icon">●</div>
          <h3>Education</h3>
          <p>When children don't walk hours for water, they attend school. Especially girls.</p>
        </div>
        <div class="impact-area">
          <div class="area-icon">◆</div>
          <h3>Economy</h3>
          <p>The economic return on water access is estimated at 4x. Productive hours, healthier workers, lower healthcare costs.</p>
        </div>
        <div class="impact-area">
          <div class="area-icon">■</div>
          <h3>Gender Equality</h3>
          <p>Returning hours to women and girls means time for education, work, and community leadership.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SDG Alignment -->
  <section class="bg-sand">
    <div class="section-inner">
      <div class="section-label">Global Framework</div>
      <div class="section-title">Aligned with the UN SDGs</div>
      <div class="sdg-grid fade-in">
        <div class="sdg-item">
          <div class="sdg-number">SDG 6</div>
          <h4>Clean Water &amp; Sanitation</h4>
          <p>Our core mission.</p>
        </div>
        <div class="sdg-item">
          <div class="sdg-number">SDG 3</div>
          <h4>Good Health &amp; Well-being</h4>
          <p>Reducing waterborne disease.</p>
        </div>
        <div class="sdg-item">
          <div class="sdg-number">SDG 5</div>
          <h4>Gender Equality</h4>
          <p>Returning time to women and girls.</p>
        </div>
        <div class="sdg-item">
          <div class="sdg-number">SDG 10</div>
          <h4>Reduced Inequalities</h4>
          <p><a href="/majimap/">MajiMap</a> exposes water pricing inequality.</p>
        </div>
        <div class="sdg-item">
          <div class="sdg-number">SDG 11</div>
          <h4>Sustainable Cities</h4>
          <p>Better urban water management.</p>
        </div>
        <div class="sdg-item">
          <div class="sdg-number">SDG 13</div>
          <h4>Climate Action</h4>
          <p>Building water resilience to climate stress.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="section-title">Be Part of the Impact</div>
    <p>Partner, donate, volunteer, or order water on the MiMaji platform.</p>
    <div class="cta-buttons">
      <a href="/take-action/" class="btn btn-white">Take Action &rarr;</a>
      <a href="https://mimaji.co.ke" target="_blank" rel="noopener" class="btn btn-outline">Visit MiMaji Platform</a>
    </div>
  </section>
</BaseLayout>

<style>
  .vision-image {
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 16px 50px rgba(10, 94, 181, 0.12);
  }

  .vision-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .image-caption {
    font-size: 0.85rem;
    color: var(--text-light);
    text-align: center;
    padding: 1rem 1.5rem;
    background: var(--white);
    font-style: italic;
    margin: 0;
  }

  .targets-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .target-card {
    padding: 2rem;
    border-radius: 16px;
    border: 1px solid var(--border);
    background: var(--white);
  }

  .target-metric {
    font-family: var(--serif);
    font-size: 2.8rem;
    color: var(--blue);
    margin-bottom: 0.3rem;
  }

  .target-label {
    font-size: 0.9rem;
    color: var(--text-light);
    line-height: 1.5;
  }

  .target-label a {
    color: var(--blue);
    font-weight: 600;
  }

  .target-label strong {
    color: var(--blue-deep);
    font-weight: 700;
  }

  .impact-areas {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }

  .impact-area {
    padding: 2.2rem;
    border-radius: 16px;
    border: 1px solid var(--border);
    background: var(--white);
    transition: all 0.3s;
  }

  .impact-area:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(10, 94, 181, 0.1);
  }

  .area-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
    color: var(--blue);
  }

  .impact-area h3 {
    font-family: var(--serif);
    font-size: 1.2rem;
    color: var(--blue-deep);
    margin-bottom: 0.6rem;
  }

  .impact-area p {
    font-size: 0.92rem;
    color: var(--text-light);
    line-height: 1.6;
  }

  .sdg-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .sdg-item {
    padding: 1.5rem;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: var(--white);
    text-align: center;
    transition: all 0.3s;
  }

  .sdg-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(10, 94, 181, 0.08);
  }

  .sdg-number {
    font-family: var(--serif);
    font-size: 1.1rem;
    color: var(--teal);
    margin-bottom: 0.4rem;
  }

  .sdg-item h4 {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--blue-deep);
    margin-bottom: 0.4rem;
  }

  .sdg-item p {
    font-size: 0.78rem;
    color: var(--text-light);
    line-height: 1.5;
  }

  .sdg-item a {
    color: var(--blue);
    font-weight: 600;
  }

  @media (max-width: 900px) {
    .impact-areas,
    .targets-grid {
      grid-template-columns: 1fr;
    }

    .sdg-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .sdg-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
