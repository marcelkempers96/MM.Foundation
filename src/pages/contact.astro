---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with MiMaji Foundation. Partner with us, volunteer, or learn more about our clean water programs across East Africa. Based in Nairobi, Kenya."
>
  <section class="page-hero">
    <div class="hero-badge">Reach Out</div>
    <h1>Get In <em>Touch</em></h1>
    <p>Whether you're looking to partner, volunteer, donate, or simply learn more — we'd love to hear from you.</p>
    <svg class="hero-wave" viewBox="0 0 1440 100" preserveAspectRatio="none">
      <path d="M0,60 C360,100 720,20 1080,60 C1260,80 1380,50 1440,60 L1440,100 L0,100Z" fill="white"/>
    </svg>
  </section>

  <section>
    <div class="section-inner">
      <div class="contact-layout">
        <!-- Contact Form -->
        <div class="contact-form-wrapper fade-in">
          <div class="section-label">Send a Message</div>
          <div class="section-title" style="font-size: 1.8rem;">We'd Love to Hear From You</div>
          <p class="form-intro">Fill out the form below and our team will get back to you within 48 hours.</p>

          <form class="contact-form" action="https://formspree.io/f/xkokwopk" method="POST">
            <div class="form-row">
              <div class="form-group">
                <label for="name">Full Name</label>
                <input type="text" id="name" name="name" placeholder="Your name" required />
              </div>
              <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" placeholder="you@example.com" required />
              </div>
            </div>
            <div class="form-group">
              <label for="subject">Subject</label>
              <select id="subject" name="subject" required>
                <option value="" disabled selected>Select a topic</option>
                <option value="partnership">Partnership Inquiry</option>
                <option value="volunteer">Volunteering</option>
                <option value="donation">Donation</option>
                <option value="media">Media / Press</option>
                <option value="water-testing">Water Testing Request</option>
                <option value="schools">Water in Schools Programme</option>
                <option value="majimap">MajiMap Data Partnership</option>
                <option value="general">General Inquiry</option>
              </select>
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" placeholder="Tell us how you'd like to get involved..." required></textarea>
            </div>
            <button type="submit" class="form-submit">Send Message &rarr;</button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="contact-info fade-in">
          <div class="info-card">
            <div class="info-icon">✉</div>
            <h4>Email</h4>
            <a href="mailto:foundation@mimaji.org">foundation@mimaji.org</a>
          </div>
          <div class="info-card highlight">
            <div class="info-icon">◆</div>
            <h4>WhatsApp</h4>
            <a href="https://wa.me/254758434076" target="_blank" rel="noopener">+254 758 434 076</a>
            <p class="info-sub">Fastest way to reach us</p>
          </div>
          <div class="info-card">
            <div class="info-icon">◉</div>
            <h4>Location</h4>
            <p>Nairobi, Kenya</p>
            <p class="info-sub">Pilot phase &mdash; Phase 1</p>
          </div>
          <div class="info-card">
            <div class="info-icon">↗</div>
            <h4>MiMaji Platform</h4>
            <a href="https://mimaji.co.ke" target="_blank" rel="noopener">mimaji.co.ke</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 4rem;
    margin-top: 1rem;
  }

  .form-intro {
    font-size: 0.95rem;
    color: var(--text-light);
    margin-top: 0.5rem;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .info-card {
    padding: 1.5rem;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: var(--sand);
    transition: all 0.3s;
  }

  .info-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(10, 94, 181, 0.08);
  }

  .info-icon {
    font-size: 1.3rem;
    margin-bottom: 0.4rem;
  }

  .info-card h4 {
    font-family: var(--serif);
    font-size: 0.95rem;
    color: var(--blue-deep);
    margin-bottom: 0.3rem;
  }

  .info-card a,
  .info-card p {
    font-size: 0.88rem;
    color: var(--text-light);
  }

  .info-card a {
    color: var(--blue);
    text-decoration: none;
  }

  .info-card a:hover {
    text-decoration: underline;
  }

  .info-card.highlight {
    background: linear-gradient(135deg, var(--blue-light), #fff);
    border-color: var(--blue);
  }

  .info-sub {
    font-size: 0.75rem;
    color: var(--text-light);
    margin-top: 0.3rem;
    font-style: italic;
  }

  @media (max-width: 900px) {
    .contact-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
